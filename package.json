{
  "name": "meristem",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "hooks:install": "bun run scripts/install-git-hooks.ts",
    "codegraph:explore": "codegraph explore",
    "codegraph:status": "codegraph status",
    "depcruise": "depcruise --config .dependency-cruiser.cjs apps services packages",
    "depcruise:html": "depcruise --config .dependency-cruiser.cjs apps services packages --output-type err-html --output-to dependency-graph.html",
    "depcruise:mermaid": "depcruise --config .dependency-cruiser.cjs apps services packages --output-type mermaid",
    "db:migrate": "bun run packages/db/src/migrate.ts",
    "db:seed": "bun run packages/db/src/seed.ts",
    "deploy:local": "bun run scripts/deploy-local.ts",
    "deploy:m-ui": "bun run scripts/run-m-ui-local.ts",
    "db:ownership-check": "bun run scripts/db-ownership-check.ts",
    "dev:all": "bun run scripts/dev-all.ts",
    "dev:backend": "bun run scripts/dev-core.ts",
    "dev:core": "bun run scripts/dev-core.ts",
    "dev:core-app": "bun run apps/core/src/index.ts",
    "dev:full": "bun run scripts/dev-full.ts",
    "dev:m-eventbus": "bun run services/m-eventbus/src/index.ts",
    "dev:m-log": "bun run services/m-log/src/index.ts",
    "dev:m-net": "bun run services/m-net/src/index.ts",
    "dev:m-task": "bun run services/m-task/src/index.ts",
    "dev:m-extension": "bun run services/m-extension/src/index.ts",
    "dev:m-policy": "bun run services/m-policy/src/index.ts",
    "dev:m-ui": "cd apps/m-ui && bun run dev",
    "dev:m-ui-bff": "bun run services/m-ui-bff/src/index.ts",
    "dev:node-agent": "bun run services/node-agent/src/index.ts",
    "dev:webui": "bun run scripts/dev-webui.ts",
    "dev:ui-demo": "bun run scripts/dev-ui-demo.ts",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false .",
    "prepare": "bun run hooks:install",
    "lint": "biome lint . && bun run scripts/boundary-import-check.ts --enforce",
    "meristem": "bun run apps/m-cli/src/index.ts",
    "mnet:harness": "bun run scripts/mnet-multihost-harness.ts",
    "mnet:harness:preflight": "bun run scripts/mnet-multihost-harness.ts preflight",
    "mnet:harness:start": "bun run scripts/mnet-multihost-harness.ts start",
    "mnet:harness:status": "bun run scripts/mnet-multihost-harness.ts status",
    "mnet:harness:stop": "bun run scripts/mnet-multihost-harness.ts stop",
    "mnet:harness:reset": "bun run scripts/mnet-multihost-harness.ts reset",
    "nix:generate": "bun run scripts/generate-nix-compose.ts",
    "skill-hygiene": "bun run scripts/skill-hygiene.ts",
    "test": "bun test tests/contracts tests/failure-modes tests/cli tests/integration --ignore tests/contracts/opensearch-search.test.ts --ignore tests/failure-modes/opensearch.test.ts",
    "test:cli": "bun test tests/cli",
    "test:contracts": "bun test tests/contracts --ignore tests/contracts/opensearch-search.test.ts",
    "test:agent-submit": "bun test tests/contracts/schema-coverage.drift.contract.test.ts tests/contracts/m-task-draft.test.ts",
    "test:e2e": "bun test --timeout=30000 tests/e2e",
    "test:failure-modes": "bun test tests/failure-modes --ignore tests/failure-modes/opensearch.test.ts",
    "test:integration": "bun test tests/integration",
    "test:ui-contract": "bun test tests/ui-contract",
    "test:perf": "bun test --timeout=60000 tests/perf",
    "test:perf:stable": "bun run scripts/run-perf.ts",
    "test:opensearch-contracts": "bun test tests/contracts/opensearch-search.test.ts",
    "test:opensearch-failure-modes": "bun test tests/failure-modes/opensearch.test.ts",
    "test:opensearch-integration": "bun test tests/integration/opensearch-projection.test.ts",
    "token:mint": "bun run packages/auth/src/mint-token.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:m-ui": "cd apps/m-ui && bun run check",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "workspace-hygiene": "bun run scripts/workspace-hygiene.ts && bun run scripts/skill-hygiene.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "1.4.2",
    "@elysiajs/eden": "1.4.9",
    "@elysiajs/openapi": "1.4.15",
    "@elysiajs/swagger": "^1.3.1",
    "@nats-io/jetstream": "^3.4.0",
    "@nats-io/nats-core": "3.4.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/context-async-hooks": "2.7.1",
    "@opentelemetry/core": "2.7.1",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@scalar/types": "0.9.5",
    "drizzle-orm": "0.45.2",
    "effect": "3.21.2",
    "elysia": "1.4.28",
    "jose": "6.2.3",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "1.3.14",
    "dependency-cruiser": "^17.4.3",
    "drizzle-kit": "latest",
    "typescript": "latest"
  }
}
