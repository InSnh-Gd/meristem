DATABASE_URL=postgres://meristem:meristem@127.0.0.1:55432/meristem
NATS_URL=ws://127.0.0.1:4223
MERISTEM_CORE_URL=http://127.0.0.1:3000
MERISTEM_TASK_URL=http://127.0.0.1:3105
MERISTEM_EXTENSION_URL=http://127.0.0.1:3106
MERISTEM_JOIN_PUBLIC_URL=https://127.0.0.1:8443
MERISTEM_JOIN_INGRESS_PORT=8443
MERISTEM_JOIN_TLS_CERT_FILE=/var/lib/meristem/certs/join-ingress-cert.pem
MERISTEM_JOIN_TLS_KEY_FILE=/var/lib/meristem/certs/join-ingress-key.pem
MERISTEM_JOIN_URL=wss://127.0.0.1:8443/join/v0/session
MERISTEM_JWT_SECRET=replace-with-a-local-secret
MERISTEM_INTERNAL_TOKEN=replace-with-a-loopback-internal-token
MERISTEM_BFF_PORT=3200
MERISTEM_UI_PORT=5173
MERISTEM_WG_BINARY_PATH=wg
MERISTEM_WSTUNNEL_BINARY_PATH=/run/current-system/sw/bin/wstunnel
MERISTEM_ACME_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory
MERISTEM_ACME_ACCOUNT_KEY=/etc/meristem/node-agent/tls/account.key
MERISTEM_HOST_PRIVATE_KEY_PATH=/etc/meristem/node-agent/wg/private.key
MERISTEM_RELAY_ENDPOINT=wss://relay.control-plane.example.com:443
MERISTEM_RELAY_PUBLIC_HOSTNAME=relay.control-plane.example.com
MERISTEM_RELAY_PUBLIC_PORT=443
MERISTEM_RELAY_PATH_PREFIX=meristem-fallback-relay
MERISTEM_RELAY_HEALTH_URL=http://127.0.0.1:19090/health
MERISTEM_WSTUNNEL_VERSION=v10.5.5
MERISTEM_OTEL_EXPORTER=console
MERISTEM_LOG_LEVEL=info
