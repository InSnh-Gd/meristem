{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "files": {
    "includes": [
      "apps/**/*.ts",
      "packages/**/*.ts",
      "scripts/**/*.ts",
      "services/**/*.ts",
      "tests/**/*.ts",
      "package.json",
      "tsconfig.base.json",
      "tsconfig.e2e.json",
      "tsconfig.json",
      "!!**/.svelte-kit",
      "!!**/.antigravitycli",
      "!!**/.codex",
      "!!**/node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "asNeeded",
      "bracketSpacing": true,
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "none"
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2,
      "trailingCommas": "none"
    }
  }
}
